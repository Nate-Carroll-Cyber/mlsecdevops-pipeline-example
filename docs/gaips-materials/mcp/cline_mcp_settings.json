{
  "mcpServers": {
    "gaips-lab-files": {
      "command": "python3",
      "args": [
        "-m",
        "gaips_lab_safe_files"
      ],
      "env": {
        "GAIPS_ROOT": "${workspaceFolder}"
      },
      "disabled": false
    },
    "gaips-fake-ticket-api": {
      "command": "python3",
      "args": [
        "-m",
        "gaips_fake_ticket_api"
      ],
      "env": {
        "ALLOW_WRITES": "false"
      },
      "disabled": false
    }
  },
  "policy": {
    "allowedRoots": [
      "${workspaceFolder}/docs/gaips-materials",
      "${workspaceFolder}/evidence"
    ],
    "network": "disabled unless instructor approves",
    "sideEffects": "deny by default; require human approval for write-like actions"
  }
}
