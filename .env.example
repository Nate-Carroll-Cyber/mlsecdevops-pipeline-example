# Browser-side Gemini access is disabled so provider keys are not exposed in the client bundle.
# Route inference through the backend API instead.

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_BASE_URL: Optional local/backend API endpoint.
# When set, the frontend calls the Counter-Spy backend /v1/intercept route for clean prompts.
VITE_API_BASE_URL="http://127.0.0.1:8080"

# OpenAI-compatible safeguard / LLM-as-a-Judge.
# This Analyst Chat firewall hop runs before any downstream responder call.
SAFEGUARDS_API_BASE_URL="https://api.openai.com/v1"
SAFEGUARDS_API_KEY=""
SAFEGUARDS_MODEL_ID="gpt-4.1-mini"

# Optional downstream responder. These settings are separate from Analyst Chat
# so Counter-Spy can sit between different model providers.
RESPONDER_PROVIDER="openai_compatible" # openai_compatible or gemini
RESPONDER_API_BASE_URL="https://api.openai.com/v1"
RESPONDER_API_KEY=""
RESPONDER_MODEL_ID="gpt-4.1-mini"
# Gemini example: RESPONDER_PROVIDER="gemini", RESPONDER_MODEL_ID="gemini-2.5-flash",
# and leave RESPONDER_API_BASE_URL blank to use the Gemini API default.

# Legacy OpenAI-compatible responder fallback. Prefer RESPONDER_* for new demos.
LLM_API_BASE_URL="https://api.openai.com/v1"
LLM_API_KEY=""
LLM_MODEL_ID="gpt-4.1-mini"

# Lara Translate backend credentials for the Playground's text-only
# auto-detect-to-English recovery path.
LARA_ACCESS_KEY_ID=""
LARA_ACCESS_KEY_SECRET=""
LARA_API_BASE_URL="https://api.laratranslate.com"

# Sam Spade local service settings.
# These are parsed separately from the main backend env so the later service split stays clean.
SAM_SPADE_ENABLED="true"
SAM_SPADE_DEFAULT_CASE_ID="case-067"
SAM_SPADE_STORE_PATH="backend/data/sam-spade.db"
SAM_SPADE_SERVICE_PORT="18120"
