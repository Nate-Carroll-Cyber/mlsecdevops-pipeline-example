# GAIPS CI Pipeline — Python dependency source file
#
# This file lists the pip packages the pipeline installs across its jobs.
# NOT covered here: tools installed by container images or standalone binaries.
# Run the following on a Python 3.11-slim Linux container to generate
# a pinned, hash-verified requirements-ci.txt:
#
#   pip install pip-tools
#   pip-compile --generate-hashes --output-file requirements-ci.txt requirements-ci.in
#
# Commit the resulting requirements-ci.txt and update CI jobs to use:
#   pip install -r ci/requirements-ci.txt
#
# Regenerate whenever a package needs to be updated.

# ── Vault / secrets ──────────────────────────────────────────────────────────
hvac

# ── Package auditing ─────────────────────────────────────────────────────────
pip-audit
pip-tools

# ── Model signing / integrity ────────────────────────────────────────────────
model-signing
sigstore

# ── Model scanning ───────────────────────────────────────────────────────────
modelscan
huggingface_hub

# ── AI red-teaming and evaluation ────────────────────────────────────────────
garak
giskard[llm]
requests
pandas
inspect-ai
inspect-evals
pyrit

# ── Watermark evaluation (heavy — audited separately by markllm-deps-audit) ──
markllm
torch
transformers

# ── Eval-dataset contract validation (eval-dataset-validate) ─────────────────
jsonschema

# ── Data redaction — PII (dataset-redact); secrets handled by gitleaks binary ─
presidio-analyzer
presidio-anonymizer
# NOTE: dataset-redact also runs `python -m spacy download en_core_web_sm`
# (spaCy is pulled in transitively by presidio-analyzer).

# ── Data quality / drift (each runs in an isolated job venv) ─────────────────
# These are installed per-job (great-expectations-validate, evidently-drift,
# ydata-profile, dvc-verify) just like giskard/markllm above, so they do not all
# have to co-resolve here; listed for SBOM completeness. ydata-profiling pins
# narrow numpy/pandas/matplotlib ranges — if pip-compile cannot resolve the full
# set together, drop it from the lockfile and rely on the job-level install.
great-expectations
evidently
ydata-profiling
dvc[all]

# ── Dependency-Track BOM upload (dependency-track-upload) ────────────────────
# requests is already listed under AI red-teaming; DT upload reuses it.

# ── Evidence reporting ───────────────────────────────────────────────────────
jinja2
