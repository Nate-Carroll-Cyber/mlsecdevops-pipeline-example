{
  "name": "react-example",
  "private": true,
  "version": "2.5.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "shared:build": "npm run build --workspace=@counter-spy/backend-shared",
    "shared:check": "npm run check --workspace=@counter-spy/backend-shared",
    "shared:clean": "npm run clean --workspace=@counter-spy/backend-shared",
    "gateway:dev": "tsx watch services/gateway/src/server.ts",
    "gateway:build": "npm run build --workspace=@counter-spy/gateway",
    "gateway:start": "node services/gateway/dist/server.js",
    "gateway:check": "npm run check --workspace=@counter-spy/gateway",
    "gateway:clean": "npm run clean --workspace=@counter-spy/gateway",
    "gateway:test": "npm run test --workspace=@counter-spy/gateway",
    "sam-spade:build": "npm run build --workspace=@counter-spy/sam-spade",
    "sam-spade:check": "npm run check --workspace=@counter-spy/sam-spade",
    "sam-spade:clean": "npm run clean --workspace=@counter-spy/sam-spade",
    "sam-spade:test": "npm run test --workspace=@counter-spy/sam-spade",
    "instruction-monitor:seed:core": "npm run instruction-monitor:seed:core --workspace=@counter-spy/gateway",
    "instruction-monitor:export:core": "npm run instruction-monitor:export:core --workspace=@counter-spy/gateway",
    "build:client": "vite build",
    "build:ssr": "vite build --ssr src/entry-server.tsx",
    "build": "npm run clean && npm run build:client && npm run build:ssr",
    "build:all": "npm run build && npm run gateway:build && npm run sam-spade:build",
    "start": "npm run build:all && node services/gateway/dist/server.js",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit && npm run shared:build && npm run gateway:check && npm run sam-spade:check",
    "test": "npm run gateway:test && npm run sam-spade:test"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.217.0",
    "@opentelemetry/auto-instrumentations-node": "^0.75.0",
    "@opentelemetry/context-zone": "^2.7.1",
    "@opentelemetry/exporter-logs-otlp-http": "^0.217.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.217.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/instrumentation": "^0.217.0",
    "@opentelemetry/instrumentation-fetch": "^0.217.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.217.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/sdk-trace-web": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@tailwindcss/vite": "^4.1.14",
    "@translated/lara": "^1.9.0",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "firebase": "^12.12.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "pgvector": "^0.2.1",
    "react": "~19.0.4",
    "react-dom": "~19.0.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "hono": "^4.12.14",
    "protobufjs": "^7.5.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "autoprefixer": "^10.4.21",
    "shadcn": "^4.2.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^8.0.5"
  }
}
