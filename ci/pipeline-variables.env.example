# =============================================================================
# MLSECDEVOPS Pipeline — CI/CD Variable Template
# =============================================================================
# One place that IS the setup. Copy the values you need into
#   GitLab → Settings → CI/CD → Variables   (persistent), or
#   Run pipeline → Variables                 (ephemeral, one run — good for tests).
#
# This file holds PLACEHOLDERS only — no real secrets — so it is safe to commit.
# GitLab's UI does not import a .env; use this as a fill-in checklist. If you
# install `glab`, it can bulk-load each line: `glab variable set KEY "value"`.
#
# Flag legend (set these in the UI when you add the variable):
#   [masked]            redact in job logs (value must match GitLab's mask charset)
#   [masked+hidden]     also un-revealable in the UI after saving
#   [protected]         injected ONLY on protected branches/tags (main is protected)
#   [plain]             not a secret — leave masking OFF
#   [expand=off]        keep "Expand variable reference" OFF (tokens may contain $)
#
# Authoritative catalog with full descriptions: ci/CI-VARIABLES.md
# Rarely-touched pins (tool versions, digest-pinned IMAGE_* ) live in the
# `variables:` block at the top of .gitlab-ci.yml — see §8 below.
# =============================================================================


# -----------------------------------------------------------------------------
# §0  Vault — LEAVE UNSET for the no-Vault demo
# -----------------------------------------------------------------------------
# Unset VAULT_ADDR is what makes the pipeline read these plain CI/CD variables
# instead of fetching from Vault. Do NOT set it unless you stand up Vault.
# VAULT_ADDR=                         # [plain] unset → plain-CI-var mode (recommended for demo)
# VAULT_NAMESPACE=                    # [plain] HCP only ("admin" / "admin/gaips"); blank for OSS/no-Vault


# -----------------------------------------------------------------------------
# §1  Model-integrity identity pair — HIGH VALUE (turns signature-verification green)
# -----------------------------------------------------------------------------
# Public verification identifiers, NOT secrets. Set [protected] (the verify job
# DEFERS on unprotected refs), masking OFF, [expand=off].
# DO NOT hand-write these — the exact full values are emitted by the manual
# `sigstore-identity-discover` job on main (commit message contains
# [sigstore-discovery]). Copy them verbatim from that job's "COPY THESE" block.
MODEL_SIGNING_IDENTITY=              # [protected][plain] full Fulcio SAN identity — paste from sigstore-identity-discover output
SIGSTORE_OIDC_ISSUER=                # [protected][plain] OIDC issuer — paste from the same job's output
# MODEL_ENDPOINT=                     # NOT used — pipeline does no inference. Leave unset.


# -----------------------------------------------------------------------------
# §2  HuggingFace provenance gate  (hf-artifact-scan)
# -----------------------------------------------------------------------------
# Opt-in: the whole job SKIPS until HF_MODEL_IDS is set.
HF_MODEL_IDS=                        # [plain] comma repo IDs, e.g. Qwen/Qwen2.5-1.5B-Instruct-GGUF ; blank → job skips
HF_AUTHOR_ALLOWLIST=                 # [plain] comma authors/orgs; blank → author check DISABLED
HF_PINNED_SHAS=                      # [plain] "org/model=<sha>,…"; blank → sha-drift check DISABLED
HF_TOKEN=                            # [masked] · [protected] optional (main-only); only needed for GATED/PRIVATE repos; public repos need nothing
# Test recipe (as Run-pipeline vars): HF_MODEL_IDS=Qwen/Qwen2.5-1.5B-Instruct-GGUF
#   pass → OK ; force fail → HF_PINNED_SHAS=Qwen/Qwen2.5-1.5B-Instruct-GGUF=deadbeef


# -----------------------------------------------------------------------------
# §3  Optional integration secrets  (blank → that job skips cleanly)
# -----------------------------------------------------------------------------
# ReversingLabs Spectra Assure (secure-software-scan). Type=Variable (not File).
# Verify first (no quota): RL_TOKEN='<PAT>' python3 scripts/secure_software_scan.py --check-token
RL_TOKEN=                            # [masked+hidden] · protect ONLY for protected-branch runs (a protected var won't inject on feature branches); blank → scan skips
RL_API_URL=                          # [plain] blank → https://data.reversinglabs.com/api/oss/community/v2/free ; Portal accounts override with a base ending in /community

# Dependency-Track (dependency-track-upload)
DT_API_URL=                          # [plain] e.g. https://dtrack.example.com (no trailing /api); blank → skips
DT_API_KEY=                          # [masked] needs BOM_UPLOAD + VIEW perms

# GitLab REST API telemetry for metrics-normalize's operational block.
# Prereq: Settings → Access Tokens → scope read_api → copy value.
GITLAB_API_TOKEN=                    # [masked+hidden] · [protected] optional (main-only telemetry) · scope read_api; blank → operational block skips (dashboard still renders)

# Auto-commit the seeded data-drift reference (data-drift-baseline-commit).
GITLAB_PUSH_TOKEN=                   # [masked+hidden] Project Access Token, scope write_repository; unset → commit the seed manually

# CI_REGISTRY_TOKEN=                 # [masked] provisioned for app/registry use; not required by the scan pipeline


# -----------------------------------------------------------------------------
# §4  Enforcement switches — teeth-last. LEAVE BLANK until the run is green,
#     then flip to enforce one at a time.
# -----------------------------------------------------------------------------
RL_FAIL_ON=malware,tampering         # "" = report-only · "malware,tampering" = gate (default already enforcing; harmless on skip)
RL_WARN_AS_FAIL=                     # "" = warnings non-blocking · e.g. "tampering" to gate on warnings too
RL_REQUIRE_TOKEN=                    # "" = skip if no token · set "true" as a PROTECTED var to hard-fail on main
DT_FAIL_ON=FAIL                      # violationState(s) that fail the DT gate (comma list)
IMAGE_VERIFY_REQUIRE=                # "" = report-only · "true" = fail if a SIGNED tool image fails to verify
DVC_REQUIRE=                         # "" = advisory · "true" = drift / unverifiable data fails the pipeline
MARKLLM_AUDIT_REQUIRE=               # "" = advisory · "true" = a NEW un-triaged CVE in torch/transformers/markllm blocks
PIP_AUDIT_REQUIRE=                   # "" = advisory · "true" = any pip-audit finding on core deps blocks
LOCK_DRIFT_REQUIRE=                  # "" = advisory warning · "true" = committed-lock drift is a hard fail
EVIDENCE_SIGNING_REQUIRED=false      # "false" = unsigned seal allowed if no id_token · "true" = missing token hard-fails


# -----------------------------------------------------------------------------
# §5  Dataset chain — defaults run in FIXTURE mode (committed gandalf split).
#     Override only to pull a real dataset from the Generic Package Registry.
# -----------------------------------------------------------------------------
DATASET_PACKAGE_NAME=                # [plain] package in the Generic Package Registry
DATASET_PACKAGE_VERSION=latest       # [plain]
DATASET_FILENAME=                    # [plain] filename to download; blank → committed fixture (fixture mode)
DATASET_FIXTURE_FILE=gandalf-ignore-instructions-test.jsonl   # [plain] fixture used in fixture mode
DATASET_EXPECTED_SHA256=667e2f643fc1881925787056274cab8829e13dc528c781125b1663a9bdb05cd6  # [plain] integrity pin (from evals/dataset-baseline.json)
DATASET_ALLOW_UNVERIFIED=            # [plain] "true" allows a download with no SHA pin (NOT recommended)
DATASETS_DISABLED=                   # [plain] "true" intentionally disables the whole dataset chain (skip green)
REDACT_MAX_SECRETS=0                 # [plain] dataset-redact hard-fails above this (0 = zero tolerance). Default lives in the job.
REDACT_MAX_PII=-1                    # [plain] PII-count gate; -1 disables (data still redacted). Default lives in the job.


# -----------------------------------------------------------------------------
# §6  Model fixture — real public model downloaded by default. Override only.
# -----------------------------------------------------------------------------
MODEL_FIXTURE_URL=https://huggingface.co/Qwen/Qwen2.5-1.5B-Instruct-GGUF/resolve/main/qwen2.5-1.5b-instruct-q2_k.gguf  # [plain] blank → skip download
MODEL_FIXTURE_PATH=qwen2.5-1.5b-instruct-gguf/qwen2.5-1.5b-instruct-q2_k.gguf   # [plain] path under models/
MODEL_FIXTURE_SHA256=5ede348e91ce1e7a330926ec5b202c27b864d065149dc463257fde1f98865b3a  # [plain] download fails on mismatch
MARKLLM_MODEL_ID=                    # [plain] blank → derived from MODEL_FIXTURE_URL at job time
MARKLLM_MODEL_REVISION=989aa7980e4cf806f80c7fef2b1adb7bc71aa306   # [plain] pinned HF commit for reproducible eval


# -----------------------------------------------------------------------------
# §7  Deploy-prep / image signing (optional — blank → those jobs skip)
# -----------------------------------------------------------------------------
IMAGE_REF=                           # [plain] workload image to sign; prefer repo@sha256:… ; blank → image-sign skips
IMAGE_REGISTRY_HOST=                 # [plain] blank → ${CI_REGISTRY}
IMAGE_REGISTRY_USER=                 # [plain] blank → ${CI_REGISTRY_USER}
IMAGE_REGISTRY_PASSWORD=             # [masked] blank → ${CI_REGISTRY_PASSWORD}
EVIDENCE_PACKAGE_NAME=gaips-evidence         # [plain] publish-signed-artifacts package
EVIDENCE_PACKAGE_VERSION=${CI_COMMIT_REF_SLUG}  # [plain] PreSync ARTIFACT_BASE_URL must point here


# -----------------------------------------------------------------------------
# §8  Defaults defined in .gitlab-ci.yml — OVERRIDE ONLY (mirror/bump)
# -----------------------------------------------------------------------------
# These have working defaults at the top of .gitlab-ci.yml. Set here only to
# point at an internal mirror or bump a tool. Image pins are digest-pinned in the
# CI file (IMAGE_SEMGREP/MINICONDA/SYFT/GRYPE/TRIVY/CYCLONEDX/GITLEAKS/CLAMAV/
# PYTHON_311/PYTHON_310/SECRETS) — roll them there, not here.
# PIP_INDEX_URL=https://pypi.org/simple/
# PIP_TRUSTED_HOST=pypi.org files.pythonhosted.org
# CONDA_CHANNEL=conda-forge
# COSIGN_VERSION=v2.4.1
# COSIGN_VERIFY_VERSION=v3.1.1
# MODEL_SIGNING_VERSION=1.1.1
# SIGSTORE_PY_VERSION=4.3.0
# MODELAUDIT_VERSION=0.2.47
# GITLEAKS_VERSION=8.30.1
# MARKLLM_VERSION=0.1.5
# TORCH_VERSION=2.12.0
# TRANSFORMERS_VERSION=4.57.6
