{
  "name": "react-example",
  "private": true,
  "version": "2.5.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "backend:dev": "tsx watch backend/src/server.ts",
    "backend:build": "tsc -p backend/tsconfig.json",
    "backend:start": "node backend/dist/server.js",
    "backend:check": "tsc -p backend/tsconfig.json --noEmit",
    "backend:test": "node --import tsx --test backend/test/*.test.ts src/lib/*.test.ts",
    "instruction-monitor:seed:core": "tsx backend/src/services/instruction-monitor/seed-core.ts",
    "instruction-monitor:export:core": "tsx backend/src/services/instruction-monitor/export-core.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit && npm run backend:check",
    "test": "npm run backend:test"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.1.14",
    "@translated/lara": "^1.9.0",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "firebase": "^12.12.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "pgvector": "^0.2.1",
    "react": "~19.0.4",
    "react-dom": "~19.0.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "hono": "^4.12.14",
    "protobufjs": "^7.5.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "autoprefixer": "^10.4.21",
    "shadcn": "^4.2.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^8.0.5"
  }
}
