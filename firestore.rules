rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - role: string (required, ['developer', 'analyst', 'engineer', 'admin'])
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - lastLogin: timestamp (optional)
    //
    // Collection: audit_logs
    // Document ID: {logId}
    // Fields:
    //   - userId: string (required)
    //   - userRole: string (required)
    //   - sessionId: string (optional)
    //   - timestamp: timestamp (required)
    //   - sanitizedPrompt: string (required)
    //   - detectionFlags: list (optional)
    //   - modelId: string (optional)
    //   - escalationRecommended: bool (optional)
    //   - entropy: number (optional)
    //   - reviewed: bool (optional)
    //
    // Collection: policies
    // Document ID: {policyId}
    // Fields:
    //   - title: string (required)
    //   - content: string (required)
    //   - category: string (optional)
    //   - lastUpdated: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function authEmail() {
      return (request.auth != null && request.auth.token.email != null)
        ? request.auth.token.email
        : '';
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "nate.carroll@natecarrollfilms.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isSecurityStaff() {
      return isAuthenticated() && 
        (isAdmin() || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['developer', 'analyst', 'engineer', 'admin']));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
        data.keys().hasOnly(['uid', 'email', 'role', 'displayName', 'photoURL', 'lastLogin']) &&
        data.uid is string &&
        data.email is string &&
        data.role in ['developer', 'analyst', 'engineer', 'admin'] &&
        (!data.keys().hasAny(['displayName']) || data.displayName is string) &&
        (!data.keys().hasAny(['photoURL']) || data.photoURL is string) &&
        (!data.keys().hasAny(['lastLogin']) || data.lastLogin is timestamp);
    }

    function isOwnerProfileCreate(userId, data) {
      return isOwner(userId) &&
        isValidUser(data) &&
        data.uid == request.auth.uid &&
        data.email == authEmail() &&
        data.role == 'developer';
    }

    function isOwnerProfileUpdate(userId, data) {
      return isOwner(userId) &&
        resource != null &&
        isValidUser(data) &&
        data.uid == resource.data.uid &&
        data.email == resource.data.email &&
        data.role == resource.data.role;
    }

    function hasNoServerOwnedAuditFields(data) {
      return !data.keys().hasAny([
        'backendGatewayStatus',
        'backendSafeguardVerdict',
        'backendSafeguardReasoning',
        'backendReachedSafeguard',
        'instructionSimilarity',
        'localPrecheckLatencyMs',
        'backendSafeguardLatencyMs',
        'backendGatewayLatencyMs',
        'instructionEmbeddingDurationMs',
        'judgeDecision',
        'forwardedPromptHash',
        'responderModel',
        'responderStatus',
        'responderLatencyMs',
        'reviewed',
        'status',
        'resultantSeverity',
        'promoted'
      ]);
    }

    function optionalString(data, field, maxSize) {
      return !data.keys().hasAny([field]) || (data[field] is string && data[field].size() <= maxSize);
    }

    function optionalNumber(data, field) {
      return !data.keys().hasAny([field]) || data[field] is number;
    }

    function optionalBool(data, field) {
      return !data.keys().hasAny([field]) || data[field] is bool;
    }

    function optionalList(data, field, maxItems) {
      return !data.keys().hasAny([field]) || (data[field] is list && data[field].size() <= maxItems);
    }

    function optionalMap(data, field) {
      return !data.keys().hasAny([field]) || data[field] is map;
    }

    function isValidAuditLog(data) {
      return data.keys().hasOnly([
          'userId',
          'userRole',
          'sessionId',
          'timestamp',
          'sanitizedPrompt',
          'detectionFlags',
          'obfuscationSummary',
          'entropy',
          'globalEntropy',
          'suspiciousChunks',
          'featureVector',
          'featurePressure',
          'researchSignal',
          'topPressureDriver',
          'topResearchDriver',
          'escalationRecommended',
          'detectionLevel',
          'latencyMs',
          'modelId',
          'source',
          'batchId',
          'expectedVerdict',
          'response',
          'contextWindowLimit',
          'contextWindowUtilization',
          'atlasTactic',
          'atlasTechniqueId',
          'atlasTechniqueName',
          'localArchetype',
          'taxonomyConfidence',
          'taxonomyNotes'
        ]) &&
        data.keys().hasAll(['userId', 'timestamp', 'sanitizedPrompt']) &&
        hasNoServerOwnedAuditFields(data) &&
        data.userId == request.auth.uid &&
        data.timestamp is timestamp &&
        data.sanitizedPrompt is string &&
        data.sanitizedPrompt.size() > 0 &&
        data.sanitizedPrompt.size() < 5000 &&
        optionalString(data, 'userRole', 64) &&
        optionalString(data, 'sessionId', 128) &&
        optionalList(data, 'detectionFlags', 40) &&
        optionalString(data, 'obfuscationSummary', 1000) &&
        optionalNumber(data, 'entropy') &&
        optionalNumber(data, 'globalEntropy') &&
        optionalList(data, 'suspiciousChunks', 50) &&
        optionalMap(data, 'featureVector') &&
        optionalMap(data, 'featurePressure') &&
        optionalMap(data, 'researchSignal') &&
        optionalString(data, 'topPressureDriver', 128) &&
        optionalString(data, 'topResearchDriver', 128) &&
        optionalBool(data, 'escalationRecommended') &&
        optionalNumber(data, 'detectionLevel') &&
        optionalNumber(data, 'latencyMs') &&
        optionalString(data, 'modelId', 128) &&
        optionalString(data, 'source', 64) &&
        optionalString(data, 'batchId', 128) &&
        optionalString(data, 'expectedVerdict', 32) &&
        optionalString(data, 'response', 5000) &&
        optionalNumber(data, 'contextWindowLimit') &&
        optionalNumber(data, 'contextWindowUtilization') &&
        optionalString(data, 'atlasTactic', 128) &&
        optionalString(data, 'atlasTechniqueId', 64) &&
        optionalString(data, 'atlasTechniqueName', 128) &&
        optionalString(data, 'localArchetype', 128) &&
        optionalNumber(data, 'taxonomyConfidence') &&
        optionalString(data, 'taxonomyNotes', 1000);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAdmin() || isOwnerProfileCreate(userId, request.resource.data);
      allow update: if isAdmin() || isOwnerProfileUpdate(userId, request.resource.data);
    }

    match /audit_logs/{logId} {
      allow read: if isSecurityStaff();
      allow create: if isAuthenticated() && isValidAuditLog(request.resource.data);
      allow delete: if isAdmin();
      allow update: if isAdmin();
    }

    match /policies/{policyId} {
      allow read: if isSecurityStaff();
      allow write: if isAdmin();
    }
    match /config/system {
      allow read, write: if isAdmin();
    }

    match /config/governance {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /config/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    match /knowledge_base/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
