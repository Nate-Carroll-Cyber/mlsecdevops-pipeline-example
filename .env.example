# Browser-side Gemini access is disabled so provider keys are not exposed in the client bundle.
# Route inference through the backend API instead.

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_BASE_URL: Optional local/backend API endpoint.
# When set, the frontend calls the Counter-Spy backend /v1/intercept route for clean prompts.
VITE_API_BASE_URL="http://127.0.0.1:8080"
VITE_BACKEND_BEARER_TOKEN="replace-with-shared-local-backend-token"
INTERCEPT_BEARER_TOKEN="replace-with-shared-local-backend-token"

# Backend hardening knobs.
# RATE_LIMIT_MAX requests per RATE_LIMIT_WINDOW_MS per caller (bearer token / IP);
# set RATE_LIMIT_MAX=0 to disable. EGRESS_ALLOWLIST is a comma-separated list of
# host or host:port entries that bypass the SSRF egress guard (needed to allow a
# private-network safeguard/responder endpoint when APP_ENV != dev).
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX="120"
EGRESS_ALLOWLIST=""
# Re-run responder LLM output through the output-side Shield before returning it.
RESPONDER_OUTPUT_SHIELD_ENABLED="true"

# OpenTelemetry. The backend exports traces/metrics/logs over OTLP only when an
# endpoint/exporter is configured below; leave OTEL_EXPORTER_OTLP_ENDPOINT unset
# (or set OTEL_SDK_DISABLED=true) for a clean no-op (structured stdout JSON only).
# The docker-compose.demo.yml stack points this at the bundled otel-collector.
OTEL_SERVICE_NAME="counter-spy-backend"
# OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
OTEL_EXPORTER_OTLP_PROTOCOL="http/json"
OTEL_TRACES_SAMPLER="parentbased_traceidratio"
OTEL_TRACES_SAMPLER_ARG="1.0"
OTEL_LOG_LEVEL="warn"
# OTEL_SDK_DISABLED="false"

# Local Docker demo pgvector database.
# Keep the password in .env.demo.local, not in docker-compose.demo.yml.
POSTGRES_PASSWORD="replace-with-strong-local-password"
INSTRUCTION_MONITOR_DATABASE_URL="postgres://counter_spy:replace-with-strong-local-password@counter-spy-postgres:5432/counter_spy"
INSTRUCTION_MONITOR_EMBEDDING_DIMENSIONS="768"
INSTRUCTION_MONITOR_EMBEDDINGS_ENABLED="true"
INSTRUCTION_MONITOR_EMBEDDINGS_API_BASE_URL="http://192.168.0.183:11434/v1"
INSTRUCTION_MONITOR_EMBEDDINGS_MODEL_ID="nomic-embed-text"
INSTRUCTION_MONITOR_EMBEDDINGS_MAX_CHUNKS="4"

# OpenAI-compatible safeguard / LLM-as-a-Judge.
# This Analyst Chat firewall hop runs before any downstream responder call.
SAFEGUARDS_API_BASE_URL="https://api.openai.com/v1"
SAFEGUARDS_API_KEY=""
SAFEGUARDS_MODEL_ID="gpt-4.1-mini"
SAFEGUARDS_TIMEOUT_MS="30000"

# Optional downstream responder. These settings are separate from Analyst Chat
# so Counter-Spy can sit between different model providers.
RESPONDER_PROVIDER="openai_compatible" # openai_compatible or gemini
RESPONDER_API_BASE_URL="https://api.openai.com/v1"
RESPONDER_API_KEY=""
RESPONDER_MODEL_ID="gpt-4.1-mini"
# Gemini example: RESPONDER_PROVIDER="gemini", RESPONDER_MODEL_ID="gemini-2.5-flash",
# and leave RESPONDER_API_BASE_URL blank to use the Gemini API default.

# Legacy OpenAI-compatible responder fallback. Prefer RESPONDER_* for new demos.
LLM_API_BASE_URL="https://api.openai.com/v1"
LLM_API_KEY=""
LLM_MODEL_ID="gpt-4.1-mini"

# Lara Translate backend credentials for the Playground's text-only
# auto-detect-to-English recovery path.
LARA_ACCESS_KEY_ID=""
LARA_ACCESS_KEY_SECRET=""
LARA_API_BASE_URL="https://api.laratranslate.com"

# Sam Spade CTF service.
# COUNTER_SPY_ROLE selects what this process serves: "gateway" (default) is the
# main Counter-Spy backend; "sam-spade" boots only the CTF routes on
# SAM_SPADE_SERVICE_PORT so the CTF surface can run as its own container.
# On a gateway, set SAM_SPADE_SERVICE_URL to reverse-proxy /v1/ctf/sam-spade/*
# to the standalone service instead of mounting the CTF handlers in-process.
COUNTER_SPY_ROLE="gateway"
# SAM_SPADE_SERVICE_URL="http://counter-spy-sam-spade-service:18120"
SAM_SPADE_ENABLED="true"
SAM_SPADE_DEFAULT_CASE_ID="case-067"
SAM_SPADE_STORE_PATH="backend/data/sam-spade.db"
SAM_SPADE_SERVICE_PORT="18120"
